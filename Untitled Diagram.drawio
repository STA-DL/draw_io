        <mxCell id="WdCX6RKOinUzmu6RYKas-19" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;2D grasping&lt;/h1&gt;&lt;div&gt;2018 - GG-CNN&lt;br&gt;&lt;/div&gt;&lt;div&gt;输入：rgb或深度图&lt;/div&gt;&lt;div&gt;输出：矩形框（x, y, w, h, theta）&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2019 - GR-ConvNet&lt;br&gt;&lt;/div&gt;&lt;div&gt;输入：RGBD&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2021 - NBMOD&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;h5 data-line=&quot;decabe3b-da45-4c74-a105-116eb260154d&quot; class=&quot;is-blur&quot;&gt;&lt;span style=&quot;font-weight: normal;&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;2021 - Grasp-Det-Seg&lt;/font&gt;&lt;/span&gt;&lt;/h5&gt;&lt;/div&gt;&lt;div&gt;DexNet 2.0&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="180" x="290" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="WdCX6RKOinUzmu6RYKas-20" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;ul&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;Cornell数据集&lt;/span&gt;:&lt;ul&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;规模&lt;/span&gt;: 1035张RGB-D图像，240个物体，5110正样本/2909负样本&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;特点&lt;/span&gt;: 真实数据，标注量较小(8019个抓取)，均衡分布但总量不足&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;Jacquard数据集&lt;/span&gt;:&lt;ul&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;规模&lt;/span&gt;: 54k RGB-D图像，含110万个抓取样本&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;特点&lt;/span&gt;: 仿真数据，规模较大适合深度学习&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;Grasp Anything数据集&lt;/span&gt;:&lt;ul&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;规模&lt;/span&gt;: 300万物体，66亿抓取，100万合成图像&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;创新&lt;/span&gt;: 使用语言提示生成逼真图像，通过预训练模型+精修方式标注&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li data-list=&quot;bullet&quot; data-list-id=&quot;5202990e-af82-401e-a0a1-bafc332b8af3&quot;&gt;&lt;span class=&quot;ql-bold-700&quot;&gt;数据趋势&lt;/span&gt;: 合成数据成为扩展规模的重要方向，但标注质量与真实数据仍有差距。&lt;/li&gt;&lt;/ul&gt;" vertex="1">
