        <mxCell id="WdCX6RKOinUzmu6RYKas-15" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;b&gt;&lt;font style=&quot;font-size: 13px; color: rgb(255, 0, 0);&quot;&gt;经典方法→监督学习→强化学习→大模型方法&lt;/font&gt;&lt;/b&gt;" vertex="1">
